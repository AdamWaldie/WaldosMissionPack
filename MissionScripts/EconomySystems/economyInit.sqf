/*
 * Author: Waldo (adapted for WaldosMissionPack - Waldos Economy Systems)
 * Bootstrap for Waldos Economy Systems (Resource / Research / Build / Buy + Ground Command).
 *
 * Runs on all machines; self-branches on isServer / hasInterface for the server
 * authority loops vs. the client Zeus-menu injection and local action loops.
 * Opt-in: gated by Waldo_Economy_Enable in init.sqf. Safe to call once per machine.
 *
 * Example:
 * [] spawn Waldo_fnc_EcoInit;
 */

missionNamespace setVariable ["WaldoEcoCore_ModulePurgedForJIP", false, true];

if (missionNamespace getVariable ["WaldoEcoCore_ModulePurgedForJIP", false]) exitWith {};
if (missionNamespace getVariable ["WaldoEcoResource_BootstrapInitialized", false]) exitWith {};
missionNamespace setVariable ["WaldoEcoResource_BootstrapInitialized", true];

if (!(missionNamespace getVariable ["WaldoEcoResource_SystemInitialized", false])) then {
    missionNamespace setVariable ["WaldoEcoResource_SystemInitialized", true];
    missionNamespace setVariable ["WaldoEcoCore_ModuleActive", true, true];
    missionNamespace setVariable ["WaldoEcoCore_ModulePurgeInProgress", false, true];
    if (isNil {missionNamespace getVariable "WaldoEcoCore_CommitmentModeEnabled"}) then {
        missionNamespace setVariable ["WaldoEcoCore_CommitmentModeEnabled", false, true];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoCore_TestingNoticeEnabled"}) then {
        missionNamespace setVariable ["WaldoEcoCore_TestingNoticeEnabled", false, true];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoCore_TestingNoticeToken"}) then {
        missionNamespace setVariable ["WaldoEcoCore_TestingNoticeToken", floor (random 1000000000), true];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoResource_ResourceMarkersVisible"}) then {
        missionNamespace setVariable ["WaldoEcoResource_ResourceMarkersVisible", true];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoResource_ActiveResourceMarkers"}) then {
        missionNamespace setVariable ["WaldoEcoResource_ActiveResourceMarkers", []];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoResource_ResourceZones"}) then {
        missionNamespace setVariable ["WaldoEcoResource_ResourceZones", []];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoCommand_GroundCommandUIDs"}) then {
        missionNamespace setVariable ["WaldoEcoCommand_GroundCommandUIDs", []];
    };
};

WaldoEcoCore_ZeusHeaderRootText = "Waldos Economy Systems";
WaldoEcoCore_ZeusHeaderRootTooltip = "Waldos Economy Systems";
WaldoEcoCore_ZeusHeaderRootColor = [0.25, 0.85, 1, 1];

if (hasInterface && {isNil "WaldoEcoCommand_LocalIdentityLoopStarted"}) then {
    WaldoEcoCommand_LocalIdentityLoopStarted = true;

    call Waldo_fnc_EcoCommand_publishLocalGroundCommandIdentity;

    [] spawn {
        while {[] call Waldo_fnc_EcoCore_isModuleActive} do {
            call Waldo_fnc_EcoCommand_publishLocalGroundCommandIdentity;
            uiSleep 2;
        };

        WaldoEcoCommand_LocalIdentityLoopStarted = nil;
    };
};

[] call Waldo_fnc_EcoResource_startZoneCaptureRequestLoop;
[] call Waldo_fnc_EcoResource_startPubZeusZoneActionBridge;

[] call Waldo_fnc_EcoResource_startCrateCollectRequestLoop;

[] call Waldo_fnc_EcoResource_initializeResourceData;

call Waldo_fnc_EcoResource_startAuthorityLoops;

if (hasInterface) then {
    [] call Waldo_fnc_EcoResource_startClientRuntime;
};

if (isNil "WaldoEcoResource_SystemInitialized" || {!(missionNamespace getVariable ["WaldoEcoResource_SystemInitialized", false])}) exitWith {};

if (!(missionNamespace getVariable ["WaldoEcoResearch_SystemInitialized", false])) then {
    WaldoEcoResearch_SystemInitialized = true;
    missionNamespace setVariable ["WaldoEcoResearch_SystemInitialized", true];
    if (isNil {missionNamespace getVariable "WaldoEcoResearch_ResearchCatalog"}) then {
        missionNamespace setVariable ["WaldoEcoResearch_ResearchCatalog", []];
    };

_fnc_installPromptInputGuard = Waldo_fnc_EcoCore_installPromptInputGuard;

    [] call Waldo_fnc_EcoResearch_startResearchRequestLoop;

    if ([] call Waldo_fnc_EcoCore_canRunBackgroundAuthority && {isNil "WaldoEcoResearch_ProgressLoopStarted"}) then {
        WaldoEcoResearch_ProgressLoopStarted = true;

        [] spawn {
            while {[] call Waldo_fnc_EcoCore_isModuleActive} do {
                uiSleep 5;
                call Waldo_fnc_EcoResearch_progressResearchQueue;
            };
        };
    };

    if (hasInterface && {isNil "WaldoEcoResearch_ZeusHookStarted"}) then {
        WaldoEcoResearch_ZeusHookStarted = true;

        [] spawn {
            private _wasOpen = false;

            while {[] call Waldo_fnc_EcoCore_isModuleActive} do {
                private _disp = call Waldo_fnc_EcoCore_getZeusDisplay;
                private _isOpen = !isNull _disp;

                if (_isOpen && !_wasOpen) then {
                    _wasOpen = true;

                    [] spawn {
                        uiSleep 0.4;

                        private _disp = call Waldo_fnc_EcoCore_getZeusDisplay;
                        if (isNull _disp) exitWith {};
                        if (_disp getVariable ["WaldoEcoResearch_MenuInjected", false]) exitWith {};

                        private _tree = [_disp] call Waldo_fnc_EcoCore_getZeusTreeControl;
                        if (isNull _tree) exitWith {};
                        [_tree] call Waldo_fnc_EcoCore_ensureZeusHeaderRoot;

                        private _menuIndexes = [_tree, [
                            "Research System",
                            "Research System",
                            "Land_PlasticCase_01_medium_F",
                            [
                                ["config", "Configure Research", "Create and edit research definitions"],
                                ["spawn", "Create Research Center", "Spawn a research center building", "Land_Research_HQ_F"]
                            ]
                        ]] call Waldo_fnc_EcoCore_injectZeusMenu;

                        private _rootIndex = _menuIndexes param [0, -1];
                        private _childIndexes = _menuIndexes param [1, []];
                        private _configChildIndex = ["config", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;
                        private _spawnChildIndex = ["spawn", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;

                        _tree setVariable ["WaldoEcoResearch_RootIndex", _rootIndex];
                        _tree setVariable ["WaldoEcoResearch_ConfigChildIndex", _configChildIndex];
                        _tree setVariable ["WaldoEcoResearch_SpawnChildIndex", _spawnChildIndex];
                        _disp setVariable ["WaldoEcoResearch_MenuInjected", true];

                        if (isNil {_tree getVariable "WaldoEcoResearch_SelectEH"}) then {
                            private _eh = _tree ctrlAddEventHandler ["TreeSelChanged", {
                                params ["_ctrl", "_path"];

                                if (_ctrl getVariable ["WaldoEcoResearch_BlockSelectionEH", false]) exitWith {};

                                private _rootIndex = _ctrl getVariable ["WaldoEcoResearch_RootIndex", -1];
                                private _configChildIndex = _ctrl getVariable ["WaldoEcoResearch_ConfigChildIndex", -1];
                                private _spawnChildIndex = _ctrl getVariable ["WaldoEcoResearch_SpawnChildIndex", -1];

                                if ((count _path) isEqualTo 2 && {(_path select 0) isEqualTo _rootIndex}) then {
                                    _ctrl setVariable ["WaldoEcoResearch_BlockSelectionEH", true];

                                    [_ctrl] spawn {
                                        disableSerialization;
                                        params ["_tree"];
                                        uiSleep 0;
                                        _tree tvSetCurSel [-1];
                                        _tree setVariable ["WaldoEcoResearch_BlockSelectionEH", false];
                                    };

                                    if ((_path select 1) isEqualTo _configChildIndex) then {
                                        [] call Waldo_fnc_EcoResearch_promptResearchConfig;
                                    };

                                    if ((_path select 1) isEqualTo _spawnChildIndex) then {
                                        [] call Waldo_fnc_EcoResearch_beginResearchCenterPlacement;
                                    };
                                };
                            }];

                            _tree setVariable ["WaldoEcoResearch_SelectEH", _eh];
                        };
                    };
                };

                if (!_isOpen && _wasOpen) then {
                    _wasOpen = false;
                };

                uiSleep 0.25;
            };
        };
    };
};

private _researchCenter = objNull;
if (!isNil "this") then {
    _researchCenter = this;
};
if (!isNull _researchCenter && {hasInterface}) then {
    [_researchCenter] call Waldo_fnc_EcoResearch_ensureResearchCenterActionsLocal;
};

if (isNil "WaldoEcoResource_SystemInitialized" || {!(missionNamespace getVariable ["WaldoEcoResource_SystemInitialized", false])}) exitWith {};

if (!(missionNamespace getVariable ["WaldoEcoBuild_SystemInitialized", false])) then {
    WaldoEcoBuild_SystemInitialized = true;
    missionNamespace setVariable ["WaldoEcoBuild_SystemInitialized", true];
    if (isNil {missionNamespace getVariable "WaldoEcoBuild_BuildCatalog"}) then {
        missionNamespace setVariable ["WaldoEcoBuild_BuildCatalog", []];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoBuild_SpawnedBuildings"}) then {
        missionNamespace setVariable ["WaldoEcoBuild_SpawnedBuildings", []];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoBuild_ActiveConstructionJobs"}) then {
        missionNamespace setVariable ["WaldoEcoBuild_ActiveConstructionJobs", []];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoBuild_ConstructionJobRuntime"}) then {
        missionNamespace setVariable ["WaldoEcoBuild_ConstructionJobRuntime", []];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoBuild_UpgradeJobRuntime"}) then {
        missionNamespace setVariable ["WaldoEcoBuild_UpgradeJobRuntime", []];
    };

    [] call Waldo_fnc_EcoBuild_startBuildingManageRequestLoop;

    [] call Waldo_fnc_EcoBuild_startConstructionRequestLoop;

    if ([] call Waldo_fnc_EcoCore_canRunBackgroundAuthority && {isNil "WaldoEcoBuild_ProductionLoopStarted"}) then {
        WaldoEcoBuild_ProductionLoopStarted = true;

        [] spawn {
            while {[] call Waldo_fnc_EcoCore_isModuleActive} do {
                uiSleep 5;
                call Waldo_fnc_EcoBuild_progressConstructionJobs;
                call Waldo_fnc_EcoBuild_progressUpgradeJobs;
                call Waldo_fnc_EcoBuild_processBuildingProduction;
            };
        };
    };
    if (hasInterface && {isNil "WaldoEcoBuild_ZeusHookStarted"}) then {
        WaldoEcoBuild_ZeusHookStarted = true;

        [] spawn {
            private _wasOpen = false;

            while {[] call Waldo_fnc_EcoCore_isModuleActive} do {
                private _disp = call Waldo_fnc_EcoCore_getZeusDisplay;
                private _isOpen = !isNull _disp;

                if (_isOpen && !_wasOpen) then {
                    _wasOpen = true;

                    [] spawn {
                        uiSleep 0.3;

                        private _disp = call Waldo_fnc_EcoCore_getZeusDisplay;
                        if (isNull _disp) exitWith {};
                        if (_disp getVariable ["WaldoEcoBuild_MenuInjected", false]) exitWith {};

                        private _tree = [_disp] call Waldo_fnc_EcoCore_getZeusTreeControl;
                        if (isNull _tree) exitWith {};
                        [_tree] call Waldo_fnc_EcoCore_ensureZeusHeaderRoot;

                        private _menuIndexes = [_tree, [
                            "Construction System",
                            "Construction System",
                            "Land_PlasticCase_01_medium_F",
                            [
                                ["config", "Configure Buildables", "Create and edit buildable definitions"],
                                ["spawn", "Spawn Building", "Spawn a configured building"],
                                ["vehicle", "Spawn Construction Vehicle", "Spawn a construction vehicle", "B_Truck_01_box_F"]
                            ]
                        ]] call Waldo_fnc_EcoCore_injectZeusMenu;

                        private _rootIndex = _menuIndexes param [0, -1];
                        private _childIndexes = _menuIndexes param [1, []];
                        private _vehicleChildIndex = ["vehicle", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;
                        private _spawnChildIndex = ["spawn", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;
                        private _configChildIndex = ["config", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;

                        _tree setVariable ["WaldoEcoBuild_RootIndex", _rootIndex];
                        _tree setVariable ["WaldoEcoBuild_VehicleChildIndex", _vehicleChildIndex];
                        _tree setVariable ["WaldoEcoBuild_SpawnChildIndex", _spawnChildIndex];
                        _tree setVariable ["WaldoEcoBuild_ConfigChildIndex", _configChildIndex];
                        _disp setVariable ["WaldoEcoBuild_MenuInjected", true];

                        if (isNil {_tree getVariable "WaldoEcoBuild_SelectEH"}) then {
                            private _eh = _tree ctrlAddEventHandler ["TreeSelChanged", {
                                params ["_ctrl", "_path"];

                                if (_ctrl getVariable ["WaldoEcoBuild_BlockSelectionEH", false]) exitWith {};

                                private _rootIndex = _ctrl getVariable ["WaldoEcoBuild_RootIndex", -1];
                                private _vehicleChildIndex = _ctrl getVariable ["WaldoEcoBuild_VehicleChildIndex", -1];
                                private _spawnChildIndex = _ctrl getVariable ["WaldoEcoBuild_SpawnChildIndex", -1];
                                private _configChildIndex = _ctrl getVariable ["WaldoEcoBuild_ConfigChildIndex", -1];

                                if ((count _path) isEqualTo 2 && {(_path select 0) isEqualTo _rootIndex}) then {
                                    _ctrl setVariable ["WaldoEcoBuild_BlockSelectionEH", true];

                                    [_ctrl] spawn {
                                        disableSerialization;
                                        params ["_tree"];
                                        uiSleep 0;
                                        _tree tvSetCurSel [-1];
                                        _tree setVariable ["WaldoEcoBuild_BlockSelectionEH", false];
                                    };

                                    if ((_path select 1) isEqualTo _vehicleChildIndex) then {
                                        [] call Waldo_fnc_EcoBuild_beginConstructionVehiclePlacement;
                                    };

                                    if ((_path select 1) isEqualTo _spawnChildIndex) then {
                                        [] call Waldo_fnc_EcoBuild_beginConfiguredBuildingPlacement;
                                    };

                                    if ((_path select 1) isEqualTo _configChildIndex) then {
                                        [] call Waldo_fnc_EcoBuild_promptBuildConfig;
                                    };
                                };
                            }];

                            _tree setVariable ["WaldoEcoBuild_SelectEH", _eh];
                        };
                    };
                };

                if (!_isOpen && _wasOpen) then {
                    _wasOpen = false;
                };

                uiSleep 0.25;
            };
        };
    };
};

if (isNil "WaldoEcoResource_SystemInitialized" || {!(missionNamespace getVariable ["WaldoEcoResource_SystemInitialized", false])}) exitWith {};

if (!(missionNamespace getVariable ["WaldoEcoBuy_SystemInitialized", false])) then {
    missionNamespace setVariable ["WaldoEcoBuy_SystemInitialized", true];

    if (isNil {missionNamespace getVariable "WaldoEcoBuy_PurchaseCatalog"}) then {
        missionNamespace setVariable ["WaldoEcoBuy_PurchaseCatalog", []];
    };
    if (isNil {missionNamespace getVariable "WaldoEcoBuy_DropPoints"}) then {
        missionNamespace setVariable ["WaldoEcoBuy_DropPoints", []];
    };

    call Waldo_fnc_EcoBuy_startAuthorityLoops;
    [] call Waldo_fnc_EcoBuy_startPurchaseRequestLoop;

    if (hasInterface && {isNil "WaldoEcoBuy_ZeusHookStarted"}) then {
        WaldoEcoBuy_ZeusHookStarted = true;

        [] spawn {
            private _wasOpen = false;

            while {[] call Waldo_fnc_EcoCore_isModuleActive} do {
                private _disp = call Waldo_fnc_EcoCore_getZeusDisplay;
                private _isOpen = !isNull _disp;

                if (_isOpen && !_wasOpen) then {
                    _wasOpen = true;
                    call Waldo_fnc_EcoBuy_startAuthorityLoops;
                    [] call Waldo_fnc_EcoBuy_startPurchaseRequestLoop;

                    [] spawn {
                        uiSleep 0.2;

                        private _disp = call Waldo_fnc_EcoCore_getZeusDisplay;
                        if (isNull _disp) exitWith {};
                        if (_disp getVariable ["WaldoEcoBuy_MenuInjected", false]) exitWith {};

                        private _tree = [_disp] call Waldo_fnc_EcoCore_getZeusTreeControl;
                        if (isNull _tree) exitWith {};
                        [_tree] call Waldo_fnc_EcoCore_ensureZeusHeaderRoot;

                        private _menuIndexes = [_tree, [
                            "Buy System",
                            "Buy System",
                            "Land_PlasticCase_01_medium_F",
                            [
                                ["config", "Configure Purchases", "Create and edit purchase definitions"],
                                ["drop", "Set Drop Point", "Create a purchase delivery point", "Land_HelipadEmpty_F"],
                                ["laptop", "Spawn Laptop", "Spawn a purchase terminal laptop", "Land_Laptop_unfolded_F"]
                            ]
                        ]] call Waldo_fnc_EcoCore_injectZeusMenu;

                        private _rootIndex = _menuIndexes param [0, -1];
                        private _childIndexes = _menuIndexes param [1, []];
                        private _configChildIndex = ["config", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;
                        private _dropChildIndex = ["drop", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;
                        private _laptopChildIndex = ["laptop", _childIndexes] call Waldo_fnc_EcoCore_getInjectedMenuChildIndex;

                        _tree setVariable ["WaldoEcoBuy_RootIndex", _rootIndex];
                        _tree setVariable ["WaldoEcoBuy_ConfigChildIndex", _configChildIndex];
                        _tree setVariable ["WaldoEcoBuy_DropChildIndex", _dropChildIndex];
                        _tree setVariable ["WaldoEcoBuy_LaptopChildIndex", _laptopChildIndex];
                        _disp setVariable ["WaldoEcoBuy_MenuInjected", true];

                        if (isNil {_tree getVariable "WaldoEcoBuy_SelectEH"}) then {
                            private _eh = _tree ctrlAddEventHandler ["TreeSelChanged", {
                                params ["_ctrl", "_path"];

                                if (_ctrl getVariable ["WaldoEcoBuy_BlockSelectionEH", false]) exitWith {};

                                private _rootIndex = _ctrl getVariable ["WaldoEcoBuy_RootIndex", -1];
                                private _configChildIndex = _ctrl getVariable ["WaldoEcoBuy_ConfigChildIndex", -1];
                                private _dropChildIndex = _ctrl getVariable ["WaldoEcoBuy_DropChildIndex", -1];
                                private _laptopChildIndex = _ctrl getVariable ["WaldoEcoBuy_LaptopChildIndex", -1];

                                if ((count _path) isEqualTo 2 && {(_path select 0) isEqualTo _rootIndex}) then {
                                    _ctrl setVariable ["WaldoEcoBuy_BlockSelectionEH", true];

                                    [_ctrl] spawn {
                                        disableSerialization;
                                        params ["_tree"];
                                        uiSleep 0;
                                        _tree tvSetCurSel [-1];
                                        _tree setVariable ["WaldoEcoBuy_BlockSelectionEH", false];
                                    };

                                    if ((_path select 1) isEqualTo _configChildIndex) then {
                                        [] call Waldo_fnc_EcoBuy_promptPurchaseConfig;
                                    };
                                    if ((_path select 1) isEqualTo _dropChildIndex) then {
                                        [] call Waldo_fnc_EcoBuy_beginDropPointPlacement;
                                    };
                                    if ((_path select 1) isEqualTo _laptopChildIndex) then {
                                        [] call Waldo_fnc_EcoBuy_beginLaptopPlacement;
                                    };
                                };
                            }];

                            _tree setVariable ["WaldoEcoBuy_SelectEH", _eh];
                        };
                    };
                };

                if (!_isOpen && _wasOpen) then {
                    _wasOpen = false;
                };

                uiSleep 0.25;
            };
        };
    };
};

