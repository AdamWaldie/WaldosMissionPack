                    _tree setVariable ["WaldoEcoCore_SavePurgeChildIndex", _purgeChildIndex];
                    _disp setVariable ["WaldoEcoCore_SaveMenuInjected", true];

                    [_tree] call Waldo_fnc_EcoCore_refreshSaveCommitmentMenuState;
                    [_tree] call Waldo_fnc_EcoCore_refreshSaveTestingNoticeMenuState;
                    if (_purgeChildIndex >= 0) then {
                        _tree tvSetColor [[_rootIndex, _purgeChildIndex], [0.80, 0.16, 0.16, 1]];
                    };

                    if (isNil {_tree getVariable "WaldoEcoCore_SaveSelectEH"}) then {
                        private _eh = _tree ctrlAddEventHandler ["TreeSelChanged", {
                            params ["_ctrl", "_path"];

                            if (_ctrl getVariable ["WaldoEcoCore_SaveBlockSelectionEH", false]) exitWith {};

                            private _rootIndex = _ctrl getVariable ["WaldoEcoCore_SaveRootIndex", -1];
                            private _commitmentChildIndex = _ctrl getVariable ["WaldoEcoCore_SaveCommitmentChildIndex", -1];
                            private _noticeChildIndex = _ctrl getVariable ["WaldoEcoCore_SaveNoticeChildIndex", -1];
                            private _transferChildIndex = _ctrl getVariable ["WaldoEcoCore_SaveTransferChildIndex", -1];
                            private _presetChildIndex = _ctrl getVariable ["WaldoEcoCore_SavePresetChildIndex", -1];
                            private _purgeChildIndex = _ctrl getVariable ["WaldoEcoCore_SavePurgeChildIndex", -1];

                            if ((count _path) isEqualTo 2 && {(_path select 0) isEqualTo _rootIndex}) then {
                                _ctrl setVariable ["WaldoEcoCore_SaveBlockSelectionEH", true];

                                [_ctrl] spawn {
                                    disableSerialization;
                                    params ["_tree"];
                                    uiSleep 0;
                                    _tree tvSetCurSel [-1];
                                    _tree setVariable ["WaldoEcoCore_SaveBlockSelectionEH", false];
                                };

                                if ((_path select 1) isEqualTo _commitmentChildIndex) then {
                                    [] call Waldo_fnc_EcoCore_toggleCommitmentMode;
                                };
                                if ((_path select 1) isEqualTo _noticeChildIndex) then {
                                    [] call Waldo_fnc_EcoCore_toggleTestingNotice;
                                };
                                if ((_path select 1) isEqualTo _transferChildIndex) then {
                                    [] call Waldo_fnc_EcoCore_promptUnifiedSaveSystem;
                                };
                                if ((_path select 1) isEqualTo _presetChildIndex) then {
                                    [] call Waldo_fnc_EcoCore_promptUnifiedPresetSystem;
                                };
                                if ((_path select 1) isEqualTo _purgeChildIndex) then {
                                    [] call Waldo_fnc_EcoCore_promptUnifiedPurgeSystem;
                                };
                            };
                        }];

                        _tree setVariable ["WaldoEcoCore_SaveSelectEH", _eh];
                    };
                };
            };

            if (!_isOpen && _wasOpen) then {
                _wasOpen = false;
            };

            uiSleep 0.25;
        };
    };
};

private _purchaseTerminal = objNull;
if (!isNil "this") then {
    _purchaseTerminal = this;
};
if (!isNull _purchaseTerminal && {hasInterface}) then {
    [_purchaseTerminal] call Waldo_fnc_EcoBuy_ensurePurchaseTerminalActionLocal;
};

if ([] call Waldo_fnc_EcoCore_canRunBackgroundAuthority) then {
    [] call Waldo_fnc_EcoCore_startTestingNoticePlayerBridge;
};

if (hasInterface && {isNil "WaldoEcoCore_LocalWorldActionLoopStarted"}) then {
    WaldoEcoCore_LocalWorldActionLoopStarted = true;

    [] spawn {
        while {[] call Waldo_fnc_EcoCore_isModuleActive} do {
            if (!isNil "Waldo_fnc_EcoResource_ensureCrateActionLocal") then {
                {
                    [_x] call Waldo_fnc_EcoResource_ensureCrateActionLocal;
                } forEach ((allMissionObjects "Land_PlasticCase_01_medium_F") select {
                    _x getVariable ["WaldoEcoResource_IsResourceCrate", false]
                });
            };

            if (!isNil "Waldo_fnc_EcoResearch_ensureResearchCenterActionsLocal") then {
                {
                    [_x] call Waldo_fnc_EcoResearch_ensureResearchCenterActionsLocal;
                } forEach ((allMissionObjects "Land_Research_HQ_F") select {
                    _x getVariable ["WaldoEcoResearch_IsResearchCenter", false]
                });
            };

            if (!isNil "Waldo_fnc_EcoBuild_ensureConstructionVehicleActionLocal") then {
                {
                    [_x] call Waldo_fnc_EcoBuild_ensureConstructionVehicleActionLocal;
                } forEach (vehicles select {
                    _x getVariable ["WaldoEcoBuild_IsConstructionVehicle", false]
                });
            };

            if (!isNil "Waldo_fnc_EcoBuy_ensurePurchaseTerminalActionLocal") then {
                {
                    [_x] call Waldo_fnc_EcoBuy_ensurePurchaseTerminalActionLocal;
                } forEach ((allMissionObjects "Land_Laptop_unfolded_F") select {
                    _x getVariable ["WaldoEcoBuy_IsPurchaseTerminal", false]
                });
            };

            uiSleep 1;
        };

        WaldoEcoCore_LocalWorldActionLoopStarted = nil;
    };
};
